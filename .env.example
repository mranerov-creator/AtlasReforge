# ── LLM ─────────────────────────────────────────────────────────────────────
# Anthropic Claude — Stage 4 code generation (primary)
ANTHROPIC_API_KEY=

# OpenAI — Stage 1 classification (cheap + fast via GPT-4o-mini)
OPENAI_API_KEY=

# Model selection (override defaults)
CLASSIFIER_MODEL=gpt-4o-mini
GENERATOR_MODEL=claude-sonnet-4-5
PARSER_MODEL=claude-haiku-4-5

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://atlasreforge:atlasreforge_dev@localhost:5432/atlasreforge

# ── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Multi-tenancy & Security ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64

# worker_thread = isolation via Node.js worker threads (dev/small deployments)
# container = isolation via separate Docker containers (enterprise)
TENANT_ISOLATION=worker_thread

# ── Ephemeral processing ─────────────────────────────────────────────────────
# CRITICAL: User code NEVER persists to disk or DB.
# Jobs are auto-purged after this TTL regardless of status.
EPHEMERAL_JOB_TTL_MS=300000

# When true: disables ALL writes of user-uploaded script content to any store.
# Only the ParsedScript output (metadata, not raw code) is stored.
DISABLE_PERSISTENCE=true

# ── Parser ───────────────────────────────────────────────────────────────────
PARSER_MAX_CONTENT_LENGTH=50000
PARSER_ENABLE_AST=true

# ── RAG Engine ───────────────────────────────────────────────────────────────
# Cron schedule for Atlassian docs re-crawl (default: Monday 2am)
ATLASSIAN_DOCS_CRAWL_SCHEDULE="0 2 * * 1"

# Minimum cosine similarity threshold for RAG retrieval
VECTOR_SIMILARITY_THRESHOLD=0.78

# Max number of RAG chunks to inject per LLM call
RAG_MAX_CHUNKS=8

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Per-tenant request limits
RATE_LIMIT_MIGRATIONS_PER_HOUR=20
RATE_LIMIT_ANALYSES_PER_HOUR=50
