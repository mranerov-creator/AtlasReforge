# ─────────────────────────────────────────────────────────────────────────────
# AtlasReforge — Local Development Environment
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Keys (required for real code generation) ─────────────────────────────
# Without these, the worker runs in mock mode (returns placeholder code).
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://atlasreforge:atlasreforge_dev@localhost:5432/atlasreforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3
HEALTH_PORT=3002

# ── Security ──────────────────────────────────────────────────────────────────
# Jobs auto-purge after 5 minutes — script content is never persisted
EPHEMERAL_JOB_TTL_MS=300000
DISABLE_PERSISTENCE=true

# ── RAG Engine ────────────────────────────────────────────────────────────────
VECTOR_SIMILARITY_THRESHOLD=0.70
# Cron: every Monday at 2am
ATLASSIAN_DOCS_CRAWL_SCHEDULE="0 2 * * 1"
